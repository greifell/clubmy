generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ALIMENTOS
  BEBIDAS
  LIMPEZA
  HIGIENE
  OUTROS
}

model Supermarket {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  state     String
  offers    Offer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, city, state])
  @@index([city, state])
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  normalized String
  category   Category @default(OUTROS)
  offers     Offer[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([normalized])
  @@index([normalized])
}

model Offer {
  id            Int         @id @default(autoincrement())
  productId     Int
  supermarketId Int
  price         Decimal     @db.Decimal(10, 2)
  imageUrl      String?
  productUrl    String?
  source        String?
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product       Product     @relation(fields: [productId], references: [id])
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])

  @@unique([productId, supermarketId, source])
  @@index([createdAt])
  @@index([expiresAt])
  @@index([productId, supermarketId])
}
model Flyer {
  id              Int      @id @default(autoincrement())
  supermarketName String
  city            String
  state           String
  title           String
  url             String
  source          String
  validFrom       DateTime?
  validUntil      DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([supermarketName, url])
}